# NeonTech PostgreSQL connection string
# Obtenerla desde: https://console.neon.tech → tu proyecto → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Clave secreta para firmar JWT (genera una cadena aleatoria larga)
# Ejemplo: openssl rand -base64 64
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria
